{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "playwright.config.ts"
  ]
}
